---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconHash from "@/assets/icons/IconHash.svg";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout pt-[68px]">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Post
      </h1>
      <a target="_blank" href="/rss.xml" class="inline-block" aria-label="rss feed" title="RSS Feed">
        <IconHash width={20} height={20} class="scale-125 stroke-accent stroke-3 rtl:-rotate-90" />
        <span class="sr-only">RSS Feed</span>
      </a>
      <p>在野保和軟體之間，曬太陽。</p>
    </section>

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-8 pb-6">
          <div id="tag-filter" class="flex flex-wrap gap-2 mb-6"></div>
          <ul id="post-list">
            {recentPosts.map((data) => (
              <li class="post-item my-3" data-tags={data.data.tags?.join(",") ?? ""}>
                <Card variant="h3" {...data} />
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }

    const posts = Array.from(document.querySelectorAll(".post-item")) as HTMLElement[];
    const tagFilter = document.querySelector("#tag-filter");
    if (!tagFilter || posts.length === 0) return;

    const allTags = new Set<string>();
    posts.forEach(p => {
      const tags = p.dataset.tags || "";
      tags.split(",").filter(Boolean).forEach((t: string) => allTags.add(t.trim()));
    });

    const makeBtn = (tag: string, label: string) => {
      const btn = document.createElement("button");
      btn.textContent = label;
      btn.dataset.tag = tag;
      btn.className = "tag-btn text-xs px-3 py-1 rounded-full border border-border text-foreground/60 hover:text-foreground transition-colors";
      if (tag === "all") {
        btn.classList.add("!bg-foreground", "!text-background", "!border-foreground");
      }
      return btn;
    };

    tagFilter.appendChild(makeBtn("all", "全部"));
    allTags.forEach(tag => tagFilter.appendChild(makeBtn(tag, tag)));

    tagFilter.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement)?.closest(".tag-btn") as HTMLElement;
      if (!btn) return;
      const selected = btn.dataset.tag || "all";

      document.querySelectorAll(".tag-btn").forEach(b => {
        (b as HTMLElement).classList.remove("!bg-foreground", "!text-background", "!border-foreground");
      });
      btn.classList.add("!bg-foreground", "!text-background", "!border-foreground");

      posts.forEach(p => {
        const tags = p.dataset.tags || "";
        const match = selected === "all" || tags.split(",").map((t: string) => t.trim()).includes(selected);
        p.style.display = match ? "" : "none";
      });
    });
  });
</script>
